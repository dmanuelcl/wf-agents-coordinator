{
  "name": "agent-coordinator",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Cross-platform Electron app for coordinating coding-agent sessions across projects and workflow checkpoints.",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-rebuild -f -w node-pty,better-sqlite3 && electron-vite dev",
    "build": "electron-rebuild -f -w node-pty,better-sqlite3 && electron-vite build",
    "typecheck": "tsc --noEmit",
    "pretest": "pnpm rebuild better-sqlite3",
    "test": "vitest run",
    "pretest:watch": "pnpm rebuild better-sqlite3",
    "test:watch": "vitest",
    "postinstall": "electron-rebuild -f -w node-pty,better-sqlite3",
    "package": "NODE_OPTIONS=\"--experimental-require-module\" pnpm run build && NODE_OPTIONS=\"--experimental-require-module\" electron-builder",
    "package:mac": "NODE_OPTIONS=\"--experimental-require-module\" pnpm run build && NODE_OPTIONS=\"--experimental-require-module\" electron-builder --mac",
    "package:win": "NODE_OPTIONS=\"--experimental-require-module\" pnpm run build && NODE_OPTIONS=\"--experimental-require-module\" electron-builder --win",
    "package:linux": "NODE_OPTIONS=\"--experimental-require-module\" pnpm run build && NODE_OPTIONS=\"--experimental-require-module\" electron-builder --linux"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12.11.1",
    "chokidar": "^5.0.0",
    "dompurify": "^3.4.11",
    "marked": "^18.0.6",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.2.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.3.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^3.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  },
  "build": {
    "appId": "com.agentcoordinator.desktop",
    "productName": "Agent Coordinator",
    "directories": {
      "output": "dist-packages"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/*.node"
    ],
    "mac": {
      "target": "dir",
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage",
      "category": "Development"
    }
  }
}
